<%- include("../partials/header", { title: title }) %>

<main class="container">

  <section class="page-header">
    <h1><%= project.name %></h1>
    <p>Project Details</p>
  </section>

  <section class="detail-card">

    <h2>Description</h2>
    <p><%= project.description %></p>

    <h3 style="margin-top: 1.5rem;">Assigned Categories</h3>

    <% if (categories && categories.length > 0) { %>
      <ul style="padding-left: 1.25rem; margin-bottom: 1rem;">
        <% categories.forEach(category => { %>
          <li><%= category.name %></li>
        <% }) %>
      </ul>
    <% } else { %>
      <p style="color: #666; font-style: italic;">No categories assigned yet.</p>
    <% } %>

  </section>

  <section class="actions" style="margin-top: 1.5rem; display: flex; gap: 1rem; flex-wrap: wrap;">

    <a href="/projects/edit/<%= project.id %>" class="btn">
      Edit Project
    </a>

    <a href="/projects/assign-category/<%= project.id %>" class="btn">
      Assign Categories
    </a>

    <a href="/projects" class="btn secondary">
      Back to Projects
    </a>

  </section>

</main>

<%- include("../partials/footer") %>