<%- include('partials/header') %> <!--[cite: 4] -->

<!-- Checklist #4: Flash Message Blocks explicitly handled -->
<% if (locals.messages) { %>
  <div class="flash-container container" style="margin-top: 1rem;">
    <%- locals.messages %>
  </div>
<% } %>

<div class="dashboard-container container" style="padding: 2rem 1rem;"> <!--[cite: 4] -->

  <h1>Dashboard</h1> <!--[cite: 4] -->

  <% if (locals.user) { %> <!--[cite: 4] -->
    <p>Welcome, <strong><%= user.name %></strong></p> <!--[cite: 4] -->
    <p>Email: <%= user.email %></p> <!--[cite: 4] -->
    <p>Role: <span class="role-badge" style="font-weight: bold; text-transform: capitalize;"><%= user.role %></span></p> <!--[cite: 4] -->
  <% } else { %> <!--[cite: 4] -->
    <p>Welcome, <strong>Guest</strong></p> <!--[cite: 4] -->
  <% } %> <!--[cite: 4] -->

  <hr style="margin: 1.5rem 0; border: 0; border-top: 1px solid #ddd;"> <!--[cite: 4] -->

  <h2>Quick Links</h2> <!--[cite: 4] -->
  <ul class="nav-links-vertical" style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; margin-top: 1rem;"> <!--[cite: 4] -->
    <li><a href="/organizations" class="btn" style="background-color: #4b5563; min-width: 200px; text-align: center;">View Organizations</a></li> <!--[cite: 4] -->
    <li><a href="/projects" class="btn" style="background-color: #4b5563; min-width: 200px; text-align: center;">View Projects</a></li> <!--[cite: 4] -->
    <li><a href="/categories" class="btn" style="background-color: #4b5563; min-width: 200px; text-align: center;">View Categories</a></li> <!--[cite: 4] -->
  </ul> <!--[cite: 4] -->

  <!-- Checklist #3 & #5: Flexible validation for lowercase, capitalized, or account_type naming conventions -->
  <% if (locals.user && (user.role === "admin" || user.role === "Admin" || user.account_type === "Admin" || user.account_type === "Employee")) { %>
    <hr style="margin: 2rem 0; border: 0; border-top: 1px solid #bfdbfe;"> <!--[cite: 4] -->

    <h2 style="color: #1e40af;">Admin Panel</h2> <!--[cite: 4] -->
    <ul style="list-style: none; padding: 0; margin-top: 1rem;"> <!--[cite: 4] -->
      <li> <!--[cite: 4] -->
        <a href="/users" class="btn" style="background-color: #1e40af; min-width: 200px; text-align: center;"> <!--[cite: 4] -->
          👤 Manage Users <!--[cite: 4] -->
        </a> <!--[cite: 4] -->
      </li> <!--[cite: 4] -->
    </ul> <!--[cite: 4] -->
  <% } %> <!--[cite: 4] -->

  <hr style="margin: 2rem 0; border: 0; border-top: 1px solid #ddd;"> <!--[cite: 4] -->

  <a href="/logout" style="color: #dc2626; font-weight: bold; text-decoration: none;">Logout</a> <!--[cite: 4] -->

</div> <!--[cite: 4] -->

<%- include('partials/footer') %> <!--[cite: 4] -->