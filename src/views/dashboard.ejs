<%- include('partials/header') %>

<div class="dashboard-container container" style="padding: 2rem 1rem;">

  <h1>Dashboard</h1>

  <% if (locals.user) { %>
    <p>Welcome, <strong><%= user.name %></strong></p>
    <p>Email: <%= user.email %></p>
    <p>Role: <span class="role-badge" style="font-weight: bold; text-transform: capitalize;"><%= user.role %></span></p>
  <% } else { %>
    <p>Welcome, <strong>Guest</strong></p>
  <% } %>

  <hr style="margin: 1.5rem 0; border: 0; border-top: 1px solid #ddd;">

  <h2>Quick Links</h2>
  <ul class="nav-links-vertical" style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; margin-top: 1rem;">
    <li><a href="/organizations" class="btn" style="background-color: #4b5563; min-width: 200px; text-align: center;">View Organizations</a></li>
    <li><a href="/projects" class="btn" style="background-color: #4b5563; min-width: 200px; text-align: center;">View Projects</a></li>
    <li><a href="/categories" class="btn" style="background-color: #4b5563; min-width: 200px; text-align: center;">View Categories</a></li>
  </ul>

  <% if (locals.user && user.role === "admin") { %>
    <hr style="margin: 2rem 0; border: 0; border-top: 1px solid #bfdbfe;">

    <h2 style="color: #1e40af;">Admin Panel</h2>
    <ul style="list-style: none; padding: 0; margin-top: 1rem;">
      <li>
        <a href="/users" class="btn" style="background-color: #1e40af; min-width: 200px; text-align: center;">
          👤 Manage Users
        </a>
      </td>
    </ul>
  <% } %>

  <hr style="margin: 2rem 0; border: 0; border-top: 1px solid #ddd;">

  <a href="/logout" style="color: #dc2626; font-weight: bold; text-decoration: none;">Logout</a>

</div>

<%- include('partials/footer') %>